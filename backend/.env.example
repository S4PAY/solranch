# Server
PORT=3001
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/solranch

# Solana
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
RANCH_TOKEN_MINT=YOUR_TOKEN_MINT_ADDRESS_HERE
REWARDS_WALLET_PRIVATE_KEY=YOUR_REWARDS_WALLET_PRIVATE_KEY_HERE

# Helius (for webhook + RPC)
HELIUS_API_KEY=YOUR_HELIUS_API_KEY_HERE
HELIUS_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET_HERE

# Frontend
FRONTEND_URL=http://localhost:5173

# Rewards
DAILY_REWARD_AMOUNT=0
